.DS_Store
*.tsbuildinfo
.idea
.vscode

# --- Docker files (don't recurse) ---
Dockerfile*
docker-compose*.yml
.dockerignore

# --- CI / GitHub ---
.github

# --- Project scratch files ---
scratch
