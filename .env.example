# =========================================================================
# RC Store Ultra - Enterprise Environmental Configuration
# Copy this file to '.env.local' and fill in your secrets.
# NEVER commit real credentials to version control.
# Generate secrets with: openssl rand -base64 32
# =========================================================================

# 1. Database Connections (Supabase / PostgreSQL)
# Pooled connection (pgBouncer) — used by Prisma at runtime
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Direct connection — used by Prisma Migrate
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# 2. Authentication (NextAuth.js)
# Local development: http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"
# REQUIRED: Generate a strong secret with: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_OPENSSL_RAND_OUTPUT"

# 3. Stripe Payment Gateway
# Test secret key from https://dashboard.stripe.com/test/apikeys
STRIPE_API_KEY="sk_test_..."
# Webhook secret from https://dashboard.stripe.com/test/webhooks
STRIPE_WEBHOOK_SECRET="whsec_..."
# Publishable key (safe for frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# 4. Cloudinary Media Asset Management
# From https://console.cloudinary.com/settings/api-keys
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# 5. Redis — Caching, Rate Limiting, Pub/Sub, BullMQ Queues
# Local Docker: redis://localhost:6379
# Upstash (production): rediss://default:TOKEN@HOST:6379
REDIS_URL="redis://localhost:6379"

# 6. Resend — Transactional Emails (REQUIRED for email flows)
# Get your key from https://resend.com/api-keys
RESEND_API_KEY="re_..."

# 7. Twilio — SMS Notifications (optional — SMS silently skipped if absent)
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="your_auth_token"
TWILIO_PHONE_NUMBER="+1234567890"

# 8. OpenAI — AI Styling Advisor and Embeddings (optional — falls back to placeholder)
OPENAI_API_KEY="sk-..."

# 9. Application Base URL (used in email links, must match deployment URL)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# 10. Global Server Configuration
PORT=3000
NODE_ENV="development"
