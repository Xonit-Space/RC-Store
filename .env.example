# =========================================================================
# RC Store — Environment Configuration Template
# Copy to .env.local and fill in values before running the app.
# =========================================================================

# ─── Database (required) ───────────────────────────────────────────────────
# Pooled connection URL (e.g. Supabase pooler port 6543)
DATABASE_URL="postgresql://user:password@host:6543/dbname?schema=public"
# Direct connection URL for Prisma migrations (e.g. Supabase port 5432)
DIRECT_URL="postgresql://user:password@host:5432/dbname?schema=public"

# ─── Authentication (required) ─────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""  # Generate: openssl rand -base64 32

# ─── Stripe (required) ───────────────────────────────────────────────────────
STRIPE_API_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ─── Redis (optional — in-memory fallback when unset/unreachable) ───────────
REDIS_URL="redis://localhost:6379"

# ─── Email (optional) ───────────────────────────────────────────────────────
RESEND_API_KEY=""

# ─── Public URLs ────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ─── WebSocket (optional — disabled when unset, typical on Vercel) ──────────
NEXT_PUBLIC_WS_URL="ws://localhost:3001"

# ─── Cloudinary (optional) ──────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── Twilio SMS (optional) ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ─── OpenAI (optional) ──────────────────────────────────────────────────────
OPENAI_API_KEY=""

# ─── Event Bus (optional) ───────────────────────────────────────────────────
EVENT_BUS_SECRET=""  # Generate: openssl rand -base64 32

# ─── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3000
