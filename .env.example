# =========================================================================
# RC Store Ultra - Enterprise Environmental Configuration
# Copy this file to '.env' and fill in the secrets for local development.
# =========================================================================

# 1. Database Connections
# For local Docker setup: postgresql://rc_admin:rc_secure_password_2026@localhost:5432/rc_store?schema=public
DATABASE_URL="postgres://..."
DIRECT_URL="postgres://..."

# 2. Authentication (NextAuth.js Setup)
# Local url: http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"
# Generate a secure secret using: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

# 3. Stripe Payments Gateways
# Your Stripe secret api test key (sk_test_...)
STRIPE_API_KEY="sk_test_..."
# Your Stripe webhook secret key (whsec_...) for payment synchronization
STRIPE_WEBHOOK_SECRET="whsec_..."
# Your public Stripe key (pk_test_...) for checkout widgets
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_public_stripe_publishable_key"

# 4. Cloudinary Media Assets Management
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

# 5. Redis Caching & Rate Limiting (Optional - Fallback to in-memory)
REDIS_URL="redis://localhost:6379"

# 6. Global Server Configuration
PORT=3000
NODE_ENV="development"

# 7. Twilio SMS API
TWILIO_ACCOUNT_SID="your_twilio_account_sid"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="+1234567890"
