datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

// ==========================================
// 1. USER, PROFILE & SECURITY SCHEMAS
// ==========================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  CUSTOMER
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String?
  avatar        String?
  image         String? // Added for NextAuth compatibility
  role          UserRole  @default(CUSTOMER)
  emailVerified DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  addresses            Address[]
  orders               Order[]
  reviews              Review[]
  wishlist             Wishlist?
  cart                 Cart?
  auditLogs            AuditLog[]
  notifications        Notification[]
  recentlyViewed       RecentlyViewed[]
  searchHistory        SearchHistory[]
  productViews         ProductView[]
  recommendationEvents RecommendationEvent[]
  abandonedCarts       AbandonedCart[]
  returnRequests       ReturnRequest[]
  giftCards            GiftCard[]
  loyaltyPoint         LoyaltyPoint?
  storeCredits         StoreCredit[]
  questions            ProductQuestion[]
  answers              ProductAnswer[]
  blogPosts            BlogPost[]
  inventoryMovements   InventoryMovement[]
  sessionLogs          SessionLog[]
  deviceFingerprints   DeviceFingerprint[]

  // NextAuth & Security Relations
  accounts  Account[]
  sessions  Session[]
  security  UserSecurity?
  StaffPick StaffPick[]

  deletedAt DateTime?

  @@index([email])
  @@map("users")
}

model Address {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  title             String   @default("Home")
  line1             String
  line2             String?
  city              String
  state             String
  postalCode        String
  country           String
  phone             String
  isDefaultShipping Boolean  @default(false)
  isDefaultBilling  Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  shippingOrders Order[] @relation("ShippingAddress")
  billingOrders  Order[] @relation("BillingAddress")

  @@index([userId])
  @@map("addresses")
}

model SessionLog {
  id                String   @id @default(cuid())
  userId            String?
  user              User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash         String   @unique
  ipAddress         String?
  userAgent         String?
  deviceFingerprint String?
  expiresAt         DateTime
  createdAt         DateTime @default(now())

  @@index([userId])
  @@map("session_logs")
}

model DeviceFingerprint {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  hash      String   @unique
  ipAddress String?
  isTrusted Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("device_fingerprints")
}

// NextAuth standard models
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Security Models
model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("password_reset_tokens")
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ipAddress String?
  success   Boolean
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@map("login_attempts")
}

model UserSecurity {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  totpSecret        String?
  totpEnabled       Boolean   @default(false)
  recoveryCodes     String    @default("[]") // JSON array of hashed codes
  failedAttempts    Int       @default(0)
  lockedUntil       DateTime?
  passwordChangedAt DateTime  @default(now())

  @@map("user_security")
}

// ==========================================
// 2. FASHION & PRODUCT CATALOG SCHEMAS
// ==========================================

enum ProductGender {
  MEN
  WOMEN
  KIDS
  UNISEX
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  image       String?
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)
  parentId    String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  @@index([slug])
  @@index([parentId])
  @@map("categories")
}

model Brand {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  logo        String?
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  @@index([slug])
  @@map("brands")
}

model Collection {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  isActive    Boolean   @default(true)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
  @@map("collections")
}

model Product {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  description   String?
  price         Decimal
  originalPrice Decimal?
  gender        ProductGender @default(UNISEX)
  isActive      Boolean       @default(true)
  isFeatured    Boolean       @default(false)
  isNewRelease  Boolean       @default(false)
  salesCount    Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  categoryId   String
  category     Category    @relation(fields: [categoryId], references: [id])
  brandId      String?
  brand        Brand?      @relation(fields: [brandId], references: [id], onDelete: SetNull)
  collectionId String?
  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)

  variants             ProductVariant[]
  images               ProductImage[]
  attributes           ProductAttribute[]
  reviews              Review[]
  wishlistItems        WishlistItem[]
  recentlyViewed       RecentlyViewed[]
  productViews         ProductView[]
  recommendationEvents RecommendationEvent[]
  questions            ProductQuestion[]
  flashSales           FlashSale[]
  compatibleModels     PartCompatibility[]
  staffPicks           StaffPick[]
  galleryImages        GalleryImage[]
  addons               ProductAddon[]

  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  @@index([slug])
  @@index([categoryId])
  @@index([brandId])
  @@index([collectionId])
  @@index([isFeatured, isActive])
  @@index([categoryId, isActive])
  @@index([categoryId, price])
  @@map("products")
}

model Addon {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  image       String?
  price       Decimal
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  products    ProductAddon[]
  cartItems   CartItem[]
  orderItems  OrderItem[]

  @@index([slug])
  @@map("addons")
}

model ProductAddon {
  productId String
  addonId   String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  addon     Addon   @relation(fields: [addonId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([productId, addonId])
  @@index([productId])
  @@index([addonId])
  @@map("product_addons")
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku       String   @unique
  price     Decimal? // Optional variant-level override
  size      String // XS, S, M, L, XL, XXL
  color     String // Hex code or visual name
  colorName String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventory  Inventory?
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([productId])
  @@index([sku])
  @@map("product_variants")
}

model ProductImage {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url        String
  alt        String?
  isFeatured Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([productId])
  @@map("product_images")
}

model ProductAttribute {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String // e.g., "Fit", "Fabric"
  value     String // e.g., "Slim Fit", "100% Cotton"

  @@index([productId])
  @@map("product_attributes")
}

model Warehouse {
  id        String   @id @default(cuid())
  name      String   @unique
  location  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventories Inventory[]

  @@map("warehouses")
}

model Inventory {
  id          String         @id @default(cuid())
  variantId   String         @unique
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity    Int            @default(0)
  reserved    Int            @default(0) // Inventory locks during active checkout sessions
  warehouseId String?
  warehouse   Warehouse?     @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  location    String? // Bin location
  updatedAt   DateTime       @updatedAt

  movements InventoryMovement[]

  @@index([warehouseId])
  @@map("inventory")
}

enum InventoryMovementType {
  STOCK_IN
  SHIPMENT
  RETURN
  ADJUSTMENT
}

model InventoryMovement {
  id          String                @id @default(cuid())
  inventoryId String
  inventory   Inventory             @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  quantity    Int // e.g. +10, -5
  type        InventoryMovementType
  userId      String?
  user        User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  reason      String?
  createdAt   DateTime              @default(now())

  @@index([inventoryId])
  @@index([userId])
  @@index([createdAt])
  @@map("inventory_movements")
}

// ==========================================
// 3. CART & WISHLIST SCHEMAS
// ==========================================

model Cart {
  id             String   @id @default(cuid())
  userId         String?  @unique
  user           User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  guestSessionId String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  items          CartItem[]
  abandonedCarts AbandonedCart[]

  @@index([userId])
  @@index([guestSessionId])
  @@map("carts")
}

model CartItem {
  id              String          @id @default(cuid())
  cartId          String
  cart            Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variantId       String?
  variant         ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  addonId         String?
  addon           Addon?          @relation(fields: [addonId], references: [id], onDelete: Cascade)
  parentProductId String?         // Reference to parent product if it's an addon
  quantity        Int             @default(1)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([cartId, variantId, addonId, parentProductId])
  @@index([cartId])
  @@index([variantId])
  @@index([addonId])
  @@map("cart_items")
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items WishlistItem[]

  @@index([userId])
  @@map("wishlists")
}

model WishlistItem {
  id         String   @id @default(cuid())
  wishlistId String
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  notifyOnRestock Boolean @default(false)
  createdAt  DateTime @default(now())

  @@unique([wishlistId, productId])
  @@index([wishlistId])
  @@index([productId])
  @@map("wishlist_items")
}

// ==========================================
// 4. CHECKOUT & ORDER SCHEMAS
// ==========================================

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ShipmentStatus {
  PENDING
  LABEL_CREATED
  IN_TRANSIT
  DELIVERED
  FAILED
}

model Order {
  id                String      @id @default(cuid())
  orderNumber       String      @unique
  userId            String
  user              User        @relation(fields: [userId], references: [id])
  status            OrderStatus @default(PENDING)
  subtotal          Decimal
  tax               Decimal
  shippingCost      Decimal
  discount          Decimal     @default(0)
  total             Decimal
  shippingAddressId String
  shippingAddress   Address     @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  billingAddressId  String
  billingAddress    Address     @relation("BillingAddress", fields: [billingAddressId], references: [id])
  couponId          String?
  coupon            Coupon?     @relation(fields: [couponId], references: [id], onDelete: SetNull)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  items    OrderItem[]
  payment  Payment?
  shipment Shipment?
  returns  ReturnRequest[]
  refunds  Refund[]

  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  @@index([userId])
  @@index([orderNumber])
  @@index([shippingAddressId])
  @@index([billingAddressId])
  @@index([status])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("orders")
}

model OrderItem {
  id              String          @id @default(cuid())
  orderId         String
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId       String?
  variant         ProductVariant? @relation(fields: [variantId], references: [id])
  addonId         String?
  addon           Addon?          @relation(fields: [addonId], references: [id])
  parentProductId String?         // Reference to parent product if it's an addon
  quantity        Int
  price           Decimal
  total           Decimal

  @@index([orderId])
  @@index([variantId])
  @@index([addonId])
  @@map("order_items")
}

model Payment {
  id            String        @id @default(cuid())
  orderId       String        @unique
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  gateway       String        @default("STRIPE")
  transactionId String        @unique
  amount        Decimal
  status        PaymentStatus @default(PENDING)
  cardBrand     String?
  cardLast4     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([orderId])
  @@index([transactionId])
  @@map("payments")
}

model Shipment {
  id                String         @id @default(cuid())
  orderId           String         @unique
  order             Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  carrier           String
  trackingNumber    String         @unique
  status            ShipmentStatus @default(PENDING)
  estimatedDelivery DateTime?
  actualDelivery    DateTime?
  courierId         String?
  courier           Courier?       @relation(fields: [courierId], references: [id], onDelete: SetNull)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([orderId])
  @@index([trackingNumber])
  @@index([status])
  @@map("shipments")
}

model Courier {
  id        String     @id @default(cuid())
  name      String
  phone     String?
  email     String?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  shipments Shipment[]

  @@map("couriers")
}

model ReturnRequest {
  id        String       @id @default(cuid())
  orderId   String
  order     Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  reason    String
  status    ReturnStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([orderId])
  @@index([userId])
  @@map("return_requests")
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  RETURNED
}

model Refund {
  id               String       @id @default(cuid())
  orderId          String
  order            Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount           Decimal
  status           RefundStatus @default(PENDING)
  gatewayReference String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([orderId])
  @@map("refunds")
}

enum RefundStatus {
  PENDING
  COMPLETED
  FAILED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

// ==========================================
// 5. MARKETING & DISCOUNTS SCHEMAS
// ==========================================

model Coupon {
  id                String   @id @default(cuid())
  code              String   @unique
  discountType      DiscountType
  discountValue     Decimal
  minOrderAmount    Decimal  @default(0)
  maxDiscountAmount Decimal?
  startDate         DateTime
  endDate           DateTime
  usageLimit        Int?
  usedCount         Int      @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  orders Order[]

  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  @@index([code])
  @@map("coupons")
}

model MarketingCampaign {
  id          String   @id @default(cuid())
  title       String
  description String?
  code        String   @unique
  discount    Decimal  @default(0)
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([code])
  @@map("marketing_campaigns")
}

model EmailSubscriber {
  id        String           @id @default(cuid())
  firstName String?
  email     String           @unique
  status    SubscriberStatus @default(ACTIVE)
  token     String           @unique // Unsubscribe cryptographic token
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([email])
  @@map("email_subscribers")
}

enum SubscriberStatus {
  ACTIVE
  UNSUBSCRIBED
}

model AbandonedCart {
  id         String   @id @default(cuid())
  cartId     String
  cart       Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastActive DateTime
  emailSent  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([cartId])
  @@index([userId])
  @@map("abandoned_carts")
}

model GiftCard {
  id            String    @id @default(cuid())
  code          String    @unique
  balance       Decimal
  initialAmount Decimal
  expiresAt     DateTime?
  isActive      Boolean   @default(true)
  userId        String?
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([code])
  @@index([userId])
  @@map("gift_cards")
}

model LoyaltyPoint {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  pointsBalance Int      @default(0)
  updatedAt     DateTime @updatedAt

  transactions LoyaltyTransaction[]

  @@map("loyalty_points")
}

model LoyaltyTransaction {
  id             String       @id @default(cuid())
  loyaltyPointId String
  loyaltyPoint   LoyaltyPoint @relation(fields: [loyaltyPointId], references: [id], onDelete: Cascade)
  points         Int // e.g. +50, -20
  reason         String // e.g. "PURCHASE_EARN", "REDEEMED"
  createdAt      DateTime     @default(now())

  @@index([loyaltyPointId])
  @@map("loyalty_transactions")
}

model StoreCredit {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  balance   Decimal  @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("store_credits")
}

// ==========================================
// 6. HEADLESS CMS & BLOG SCHEMAS
// ==========================================

model CMSPage {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  content        String // JSON string for dynamic grids layout sections
  seoTitle       String?
  seoDescription String?
  published      Boolean   @default(false)
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([slug])
  @@map("cms_pages")
}

model BlogPost {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  content     String
  excerpt     String?
  coverImage  String?
  published   Boolean      @default(false)
  publishedAt DateTime?
  authorId    String?
  author      User?        @relation(fields: [authorId], references: [id], onDelete: SetNull)
  categoryId  String
  category    BlogCategory @relation(fields: [categoryId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tags BlogTag[]

  @@index([slug])
  @@index([authorId])
  @@map("blog_posts")
}

model BlogCategory {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  posts     BlogPost[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([slug])
  @@map("blog_categories")
}

model BlogTag {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  posts     BlogPost[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([slug])
  @@map("blog_tags")
}

// ==========================================
// 7. RC SPECIALTY & LANDING PAGE SCHEMAS
// ==========================================

model VehicleMake {
  id        String         @id @default(cuid())
  name      String         @unique
  slug      String         @unique
  logo      String?
  models    VehicleModel[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([slug])
  @@map("vehicle_makes")
}

model VehicleModel {
  id              String              @id @default(cuid())
  makeId          String
  make            VehicleMake         @relation(fields: [makeId], references: [id], onDelete: Cascade)
  name            String
  slug            String              @unique
  scale           String? // e.g., "1/10", "1/8"
  type            String? // e.g., "Monster Truck", "Crawler"
  image           String?
  compatibilities PartCompatibility[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([slug])
  @@index([makeId])
  @@map("vehicle_models")
}

model PartCompatibility {
  id             String       @id @default(cuid())
  productId      String
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  vehicleModelId String
  vehicleModel   VehicleModel @relation(fields: [vehicleModelId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([productId, vehicleModelId])
  @@index([productId])
  @@index([vehicleModelId])
  @@map("part_compatibilities")
}

model StaffPick {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  roleTitle String // e.g., "Lead Technician"
  quote     String   @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([userId])
  @@map("staff_picks")
}

model GalleryImage {
  id         String   @id @default(cuid())
  imageUrl   String
  caption    String?  @db.Text
  authorName String? // e.g. "@neoshopultra"
  productId  String?
  product    Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  sortOrder  Int      @default(0)
  isApproved Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([productId])
  @@map("gallery_images")
}

model NavigationMenu {
  id        String   @id @default(cuid())
  name      String
  location  String   @unique // e.g. "HEADER", "FOOTER"
  items     String // JSON nested tree links structure
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("navigation_menus")
}

model FAQ {
  id        String   @id @default(cuid())
  category  String
  question  String
  answer    String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faqs")
}

model HeroBanner {
  id        String    @id @default(cuid())
  title     String
  subtitle  String?
  image     String
  link      String?
  isActive  Boolean   @default(true)
  startDate DateTime?
  endDate   DateTime?
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("hero_banners")
}

model FlashSale {
  id              String   @id @default(cuid())
  name            String
  discountPercent Decimal
  startDate       DateTime
  endDate         DateTime
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  products Product[]

  @@map("flash_sales")
}

// ==========================================
// 7. INTERNATIONALIZATION & LOCALIZATION
// ==========================================

model Currency {
  id           String   @id @default(cuid())
  code         String   @unique // USD, EUR, GBP, LKR
  symbol       String
  exchangeRate Decimal  @default(1.0) // Relative to USD base
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  regions Region[]

  @@index([code])
  @@map("currencies")
}

model Region {
  id         String   @id @default(cuid())
  name       String   @unique
  code       String   @unique // US, EU, GB, LK
  currencyId String
  currency   Currency @relation(fields: [currencyId], references: [id])
  taxRateId  String?  @unique
  taxRate    TaxRate? @relation(fields: [taxRateId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@map("regions")
}

model TaxRate {
  id        String   @id @default(cuid())
  name      String
  rate      Decimal // e.g. 0.08 for 8%
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  region Region?

  @@map("tax_rates")
}

model ShippingZone {
  id            String   @id @default(cuid())
  name          String
  countries     String // JSON array of strings
  rate          Decimal
  estimatedDays String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("shipping_zones")
}

// ==========================================
// 8. TELEMETRY, LOGGING & FEATURE CONTROLS
// ==========================================

model SearchHistory {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  query     String
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("search_histories")
}

model SearchAnalytics {
  id           String   @id @default(cuid())
  query        String   @unique
  count        Int      @default(1)
  resultsCount Int      @default(0)
  clicksCount  Int      @default(0)
  updatedAt    DateTime @updatedAt

  @@index([query])
  @@map("search_analytics")
}

model ProductView {
  id                String   @id @default(cuid())
  userId            String?
  user              User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId         String
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  deviceFingerprint String?
  createdAt         DateTime @default(now())

  @@index([userId])
  @@index([productId])
  @@map("product_views")
}

model RecommendationEvent {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  algoType  String // "COLLABORATIVE", "CATEGORY_AFFINITY", "TRENDING"
  event     String // "IMPRESSION", "CLICK", "PURCHASE"
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([productId])
  @@map("recommendation_events")
}

model ProductQuestion {
  id           String   @id @default(cuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  questionText String
  isApproved   Boolean  @default(false)
  createdAt    DateTime @default(now())

  answers ProductAnswer[]

  @@index([productId])
  @@index([userId])
  @@map("product_questions")
}

model ProductAnswer {
  id         String          @id @default(cuid())
  questionId String
  question   ProductQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  answerText String
  isApproved Boolean         @default(false)
  createdAt  DateTime        @default(now())

  @@index([questionId])
  @@index([userId])
  @@map("product_answers")
}

model WebhookEvent {
  id            String    @id @default(cuid())
  stripeEventId String    @unique // Stripe event.id — final ordering authority
  stripeCreated Int // Stripe event.created (Unix epoch) — for ordering
  eventType     String
  payload       String // JSON string
  status        String // "PENDING", "PROCESSED", "FAILED"
  errorMessage  String?
  createdAt     DateTime  @default(now())
  processedAt   DateTime?

  @@index([stripeEventId])
  @@index([eventType])
  @@index([status])
  @@map("webhook_events")
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  isEnabled   Boolean  @default(false)
  rules       String? // JSON rules
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@map("feature_flags")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  ipAddress String?
  userAgent String?
  changes   String? // JSON
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}

model SiteSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@map("site_settings")
}

model Review {
  id        String   @id @default(cuid())
  rating    Int // 1 to 5
  comment   String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images ReviewImage[]

  @@index([userId])
  @@index([productId])
  @@index([productId, rating])
  @@unique([userId, productId])
  @@map("reviews")
}

model ReviewImage {
  id       String @id @default(cuid())
  reviewId String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  url      String

  @@index([reviewId])
  @@map("review_images")
}

model RecentlyViewed {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  viewedAt  DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@map("recently_viewed")
}

enum NotificationType {
  ORDER
  PAYMENT
  SYSTEM
  INVENTORY
  PROMO
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  title     String
  message   String
  type      NotificationType @default(SYSTEM)
  read      Boolean          @default(false)
  metadata  Json? // Event payload context details
  createdAt DateTime         @default(now())

  @@index([userId])
  @@map("notifications")
}

model DomainEventLog {
  id        String   @id @default(cuid())
  eventId   String   @unique
  eventType String
  payload   String // JSON string
  signature String? // HMAC signature for security audit
  status    String   @default("PUBLISHED") // PUBLISHED, REPLAYED, FAILED
  createdAt DateTime @default(now())

  @@index([eventType])
  @@index([createdAt])
  @@map("domain_event_logs")
}

// ==========================================
// 9. DISTRIBUTED RESILIENCE ENGINE SCHEMAS
// ==========================================

// Hybrid idempotency: Redis fast-path + DB final authority
model IdempotencyRecord {
  id         String   @id @default(cuid())
  key        String   @unique // SHA-256 of (namespace:requestId)
  namespace  String // "stripe_webhook", "checkout", "pos_sale"
  resultJson String? // Cached response payload (JSON)
  status     String   @default("PROCESSING") // PROCESSING | COMPLETED | FAILED
  expiresAt  DateTime // TTL — after which record can be pruned
  createdAt  DateTime @default(now())

  @@index([key])
  @@index([expiresAt])
  @@map("idempotency_records")
}

// 3-phase inventory reservation engine
enum ReservationStatus {
  RESERVED
  COMMITTED
  RELEASED
}

model InventoryReservation {
  id          String            @id @default(cuid())
  variantId   String
  quantity    Int
  checkoutId  String // Stripe session ID or POS transaction ID
  status      ReservationStatus @default(RESERVED)
  expiresAt   DateTime // RESERVED auto-releases after this
  committedAt DateTime?
  releasedAt  DateTime?
  createdAt   DateTime          @default(now())

  @@index([variantId])
  @@index([checkoutId])
  @@index([status])
  @@index([expiresAt])
  @@map("inventory_reservations")
}

// Dead letter queue for failed financial events
enum DLQStatus {
  PENDING
  RETRYING
  RESOLVED
  ESCALATED
}

model FinancialDLQ {
  id           String    @id @default(cuid())
  eventId      String    @unique // Original event/idempotency key
  namespace    String // "stripe_webhook", "order_creation", "inventory_commit"
  payloadJson  String // Original event payload
  errorMessage String
  retryCount   Int       @default(0)
  maxRetries   Int       @default(5)
  status       DLQStatus @default(PENDING)
  lastAttempt  DateTime?
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status])
  @@index([namespace])
  @@index([eventId])
  @@map("financial_dlq")
}

// Daily payment reconciliation reports
model ReconciliationReport {
  id                String   @id @default(cuid())
  reportDate        DateTime @unique // Date being reconciled
  stripeTotal       Decimal // Total from Stripe
  dbTotal           Decimal // Total from DB payments
  delta             Decimal // Difference (should be 0)
  missingInDB       String   @default("[]") // JSON array of Stripe PI IDs
  missingInStripe   String   @default("[]") // JSON array of DB payment IDs
  mismatchedAmounts String   @default("[]") // JSON array of {orderId, stripe, db}
  duplicateOrders   String   @default("[]") // JSON array of orderNumbers
  status            String   @default("PENDING") // PENDING | CLEAN | DISCREPANCY
  createdAt         DateTime @default(now())

  @@index([reportDate])
  @@index([status])
  @@map("reconciliation_reports")
}
